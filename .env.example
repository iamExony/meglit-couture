# Paystack API Keys (get from https://dashboard.paystack.com/#/settings/developer)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of the deployed app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin credentials & session secret
# Generate a strong secret, e.g.: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

